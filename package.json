{
    "name": "pallete-creator",
    "version": "0.5.0",
    "description": "A simple color scheme generator for the web",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "check": "pnpm lint && pnpm test:ci && pnpm build",
        "dev": "vite",
        "build": "vite build",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "serve": "vite preview",
        "test": "vitest",
        "test:ci": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true"
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^6.0.0",
        "@fortawesome/free-brands-svg-icons": "^6.0.0",
        "@fortawesome/free-regular-svg-icons": "^6.0.0",
        "@fortawesome/free-solid-svg-icons": "^6.0.0",
        "@fortawesome/vue-fontawesome": "^3.0.0",
        "mosha-vue-toastify": "^1.0.23",
        "vue": "^3.2.16",
        "vuex": "^4.0.2"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.0.0",
        "@vitest/coverage-v8": "^3.0.9",
        "@vitest/ui": "^3.0.9",
        "@vue/test-utils": "^2.0.0",
        "jsdom": "^25.0.1",
        "oxlint": "^1.55.0",
        "vite": "^5.4.18",
        "vitest": "^3.0.9"
    }
}
