{
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "lib": ["dom", "es2023", "DOM.Iterable"],
        "noEmit": true,
        "moduleResolution": "bundler",
        "module": "esnext",
        "strict": true,
        "noPropertyAccessFromIndexSignature": true,
        "noUncheckedIndexedAccess": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "target": "es2023",
        "types": ["vitest/globals"]
    },
    "include": ["src/**/*"]
}
